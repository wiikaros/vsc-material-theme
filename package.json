{
  "name": "vsc-material-theme-italicize",
  "displayName": "Material Theme Italicize",
  "description": "A fork of vsc-material-theme introducing syntactical sugar (like italicizing keywords)",
  "version": "0.0.13",
  "publisher": "wiikaros",
  "license": "Apache-2.0",
  "icon": "logo.png",
  "galleryBanner": {
    "color": "#263238",
    "theme": "dark"
  },
  "homepage": "https://github.com/faultless/vsc-material-theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/faultless/vsc-material-theme.git"
  },
  "bugs": {
    "url": "https://github.com/faultless/vsc-material-theme/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "scripts": {
    "build": "npm run build-icons && npm run build-themes && npm run build-icons-accents && npm run build-icons-variants",
    "minimize-icons": "svgo -f src/icons/svgs -o icons",
    "minimize-json": "json-minify themes/.material-theme-icons.tmp > themes/Material-Theme-Icons.json && npm run remove-icons-tmp",
    "remove-icons": "rimraf icons && rimraf themes/Material-Theme-Icons.json",
    "remove-icons-tmp": "rimraf themes/.material-theme-icons.tmp",
    "build-icons": "npm run remove-icons && npm run minimize-icons && gulp build:icons && npm run minimize-json",
    "build-icons-accents": "gulp build:icons.accents",
    "build-icons-variants": "gulp build:icons.variants",
    "build-themes": "gulp build:themes",
    "release": "npm run bump && npm run changelog",
    "postinstall": "node ./node_modules/vscode/bin/install",
    "changelog": "gulp changelog",
    "bump": "gulp bump",
    "tsc": "tsc"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./extensions/accent-setter.js",
  "contributes": {
    "commands": [
      {
        "category": "Material Theme",
        "command": "material.theme.setAccent",
        "title": "Set Accent Color"
      }
    ],
    "themes": [
      {
        "label": "Material Theme Italicize Default",
        "uiTheme": "vs-dark",
        "path": "./themes/Material-Theme-Default.json"
      },
      {
        "label": "Material Theme Italicize Default HC",
        "uiTheme": "vs-dark",
        "path": "./themes/Material-Theme-Default-High-Contrast.json"
      },
      {
        "label": "Material Theme Italicize Darker",
        "uiTheme": "vs-dark",
        "path": "./themes/Material-Theme-Darker.json"
      },
      {
        "label": "Material Theme Italicize Darker HC",
        "uiTheme": "vs-dark",
        "path": "./themes/Material-Theme-Darker-High-Contrast.json"
      },
      {
        "label": "Material Theme Italicize Palenight",
        "uiTheme": "vs-dark",
        "path": "./themes/Material-Theme-Palenight.json"
      },
      {
        "label": "Material Theme Italicize Palenight HC",
        "uiTheme": "vs-dark",
        "path": "./themes/Material-Theme-Palenight-High-Contrast.json"
      },
      {
        "label": "Material Theme Italicize Lighter",
        "uiTheme": "vs",
        "path": "./themes/Material-Theme-Lighter.json"
      },
      {
        "label": "Material Theme Italicize Lighter HC",
        "uiTheme": "vs",
        "path": "./themes/Material-Theme-Lighter-High-Contrast.json"
      }
    ],
    "iconThemes": [
      {
        "id": "wiikaros-material-theme-icons",
        "label": "Material Theme Icons",
        "path": "./themes/Material-Theme-Icons.json"
      }
    ]
  },
  "devDependencies": {
    "@types/chalk": "0.4.31",
    "@types/gulp": "4.0.4",
    "@types/gulp-if": "0.0.31",
    "@types/gulp-util": "3.0.31",
    "@types/mustache": "0.8.29",
    "@types/run-sequence": "0.0.29",
    "@types/through2": "2.0.33",
    "@types/vscode": "1.85.0",
    "@types/yamljs": "0.2.30",
    "@types/yargs": "6.6.0",
    "babel-core": "6.25.0",
    "babel-preset-es2015": "6.24.1",
    "babel-root-import": "4.1.8",
    "cpx": "1.5.0",
    "eslint": "4.1.1",
    "eslint-plugin-standard": "3.0.1",
    "gulp": "3.9.1",
    "gulp-bump": "2.7.0",
    "gulp-conventional-changelog": "1.1.3",
    "gulp-if": "2.0.2",
    "gulp-stats": "0.0.4",
    "gulp-util": "3.0.8",
    "json-minify": "1.0.0",
    "mustache": "2.3.0",
    "rimraf": "2.6.1",
    "run-sequence": "1.2.2",
    "svgo": "0.7.1",
    "typescript": "2.4.1",
    "vscode": "1.1.1",
    "yamljs": "0.3.0",
    "yargs": "8.0.2"
  }
}
